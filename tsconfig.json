{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    //  changes the type of the error in a catch from unknown to any
    "useUnknownInCatchVariables": false,
    "paths": {
      "app/*": ["./app/*"],
      "components/*": ["./app/components/*"],
      "constants/*": ["./app/constants/*"],
      "feature/*": ["./app/feature/*"],
      "modules/*": ["./app/modules/*"],
      "screens/*": ["./app/screens/*"],
      "api/*": ["./app/api/*"],
      "navigation/*": ["./app/navigation/*"],
      "store/*": ["./app/store/*"],
      "db": ["./db"],
      "db/*": ["./db/*"],
      "drizzle/*": ["./drizzle/*"]
    }
  },
  "exclude": ["node_modules"]
}
