{
  "name": "spendy_fly",
  "version": "1.1.1",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "yarn expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "apk_eas": "eas build -p android --profile preview",
    "apk_prod": "eas build --platform android --profile production",
    "apk": "cross-env APP_VARIANT=preview npx expo prebuild --clean -p android && cross-env APP_VARIANT=preview npx expo run:android --variant release",
    "prebuild": "npx expo prebuild",
    "db:generate": "npx drizzle-kit generate",
    "db:customMigrate": "npx drizzle-kit generate --custom"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "5.2.9",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "^7.8.4",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/native-stack": "^7.6.2",
    "@react-navigation/stack": "^7.6.3",
    "@tanstack/react-query": "^5.60.5",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "expo": "^56.0.0",
    "expo-checkbox": "~56.0.1",
    "expo-document-picker": "~56.0.4",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "formik": "^2.2.9",
    "mathjs": "^15.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-dialog": "^9.3.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-charts": "^1.4.54",
    "react-native-popup-menu": "^0.16.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tanstack/eslint-plugin-query": "^5.60.1",
    "@types/react": "^19",
    "babel-plugin-import": "^1.13.8",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "baseline-browser-mapping": "^2.10.18",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.6",
    "typescript": "~6.0.3"
  },
  "private": true
}
